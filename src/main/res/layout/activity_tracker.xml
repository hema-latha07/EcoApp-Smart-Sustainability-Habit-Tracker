<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F9F4">

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2D5A27"
        android:padding="10dp">

        <ImageButton
            android:id="@+id/btnBackTracker"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Eco Tracker"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_margin="20dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Distance"
                android:textColor="#666666"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 m"
                android:textColor="#2D5A27"
                android:textSize="48sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eco Points Gained"
                android:textColor="#666666"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPointsGained"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF9800"
                android:textSize="32sp"
                android:textStyle="bold" />
            <Button
                android:id="@+id/btnDownloadCertificate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Download Certificate"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:visibility="gone"
                android:layout_marginTop="10dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTrackingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Ready to track"
            android:textAlignment="center"
            android:layout_marginBottom="15dp"
            android:textColor="#888888" />

        <Button
            android:id="@+id/btnToggleTracking"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#2D5A27"
            android:text="Start Green Journey"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:cornerRadius="30dp" />
    </LinearLayout>

</RelativeLayout>