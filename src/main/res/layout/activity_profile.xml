<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F9F4"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#2D5A27" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Profile"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2D5A27"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="50dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        app:cardElevation="4dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_myplaces"
            android:padding="20dp"
            app:tint="#4CAF50" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="15dp"
        android:layout_marginBottom="25dp"
        app:cardElevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="15dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvProfileRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eco Hero"
                    android:textColor="#2D5A27"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Status"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>
            <TextView
                android:id="@+id/tvProfilePoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 pts"
                android:textColor="#2D5A27"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Full Name"
        android:textColor="#666666"
        android:textSize="14sp" />
    <TextView
        android:id="@+id/tvProfileName"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Loading..."
        android:textSize="18sp"
        android:gravity="center_vertical"
        android:paddingLeft="15dp"
        android:background="@drawable/gradient_green_light"
        android:layout_marginBottom="20dp"
        android:textColor="#1B3A1E" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Email Address"
        android:textColor="#666666"
        android:textSize="14sp" />
    <TextView
        android:id="@+id/tvProfileEmail"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Loading..."
        android:textSize="18sp"
        android:gravity="center_vertical"
        android:paddingLeft="15dp"
        android:background="@drawable/gradient_green_light"
        android:layout_marginBottom="30dp"
        android:textColor="#1B3A1E" />
    <Button
        android:id="@+id/btnDownloadCertProfile"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Download Certificate"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="10dp"
        app:icon="@android:drawable/ic_menu_save" />
    <Button
        android:id="@+id/btnEditProfile"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Edit Profile"
        android:backgroundTint="#2D5A27"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        app:cornerRadius="10dp" />

</LinearLayout>