<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F9F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EcoHero Admin Control"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#2D5A27"
            android:layout_marginBottom="20dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="10dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Students" android:textSize="18sp"/>
                <TextView android:id="@+id/tvAdminTotalUsers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#2E7D32" android:textStyle="bold" android:textSize="20sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="10dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Global Eco-Impact" android:textSize="18sp"/>
                <TextView android:id="@+id/tvAdminGlobalPoints" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50 pts" android:textColor="#2E7D32" android:textStyle="bold" android:textSize="20sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="10dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Certificates Issued" android:textSize="18sp"/>
                <TextView android:id="@+id/tvAdminCertsCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#2E7D32" android:textStyle="bold" android:textSize="20sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnRefreshAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Data"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campus Broadcast"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2D5A27"
            android:layout_marginBottom="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="20dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="15dp"
                android:orientation="vertical">
                <EditText
                    android:id="@+id/etCampusAlert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Type alert (e.g. Tree Planting Drive)"
                    android:background="@android:color/transparent"
                    android:padding="10dp"/>
                <Button
                    android:id="@+id/btnSendAlert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Post Alert to Dashboard"
                    android:backgroundTint="#FFC107"
                    android:textColor="#000000"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnResetMonthly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset Monthly Leaderboard"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>