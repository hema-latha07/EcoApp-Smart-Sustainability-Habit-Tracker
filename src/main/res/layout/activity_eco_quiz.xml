<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FAF6">

    <RelativeLayout
        android:id="@+id/headerQuiz"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2D5A27"
        android:padding="10dp">

        <ImageButton
            android:id="@+id/btnBackQuiz"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Back"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvQuizTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Eco Challenge"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerQuiz"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="30dp">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="@android:color/white"
            android:layout_marginBottom="20dp"/>
        <TextView
            android:id="@+id/tvQuizProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 5"
            android:textColor="#2D5A27"
            android:textStyle="bold"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp" />
        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Loading your eco-task..."
            android:textColor="#333333"
            android:textSize="18sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/btnOption1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#FFFFFF"
            android:text="Option 1"
            android:textColor="#2D5A27"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:elevation="4dp"
            android:layout_marginBottom="15dp" />

        <Button
            android:id="@+id/btnOption2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#2D5A27"
            android:text="Option 2"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:elevation="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Choose the correct eco-friendly action to earn points!"
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"/>

    </LinearLayout>
</RelativeLayout>